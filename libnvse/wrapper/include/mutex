#pragma once
namespace std {
    class mutex {
    public:
        void lock() {}
        void unlock() {}
        bool try_lock() { return true; }
    };

    template<typename T>
    class lock_guard {
    public:
        explicit lock_guard(T&) {}
    };

    template<typename T>
    class unique_lock {
    public:
        explicit unique_lock(T&) {}
    };
}
